desktop.ini
$RECYCLE.BIN/

# macOS
.AppleDouble
.LSOverride
._*

# ─── Logs ────────────────────────────────────────────────────────────────
*.log
logs/

# ─── Testing ─────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/

# ─── Jupyter ─────────────────────────────────────────────────────────────
.ipynb_checkpoints/
